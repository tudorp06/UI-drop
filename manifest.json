{
  "manifest_version": 3,
  "name": "UIDrop: Snap a site's Design System to Claude, GPT, Lovable, Manus, Cursor",
  "version": "1.0.8",
  "description": "Extract colors, fonts, spacing & components — buttons, cards, chips — from any site. Send to Claude, GPT, Cursor, Lovable or Manus.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "UIDrop — Snap this page's design"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://lovable.dev/*",
    "https://manus.im/*",
    "https://extensionpay.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["library.html", "library.js", "icons/*", "icons/lovable-color.png", "icons/manus.png"],
      "matches":   ["<all_urls>"]
    }
  ],

  "content_scripts": []
}
