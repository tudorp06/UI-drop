{
  "manifest_version": 3,
  "name": "UIDrop — Design System Extractor for AI",
  "version": "1.5.0",
  "description": "Extract any site's colors, fonts, spacing & components in one click. Send to Claude, ChatGPT, Gemini, Cursor, Lovable or Manus.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "UIDrop — Snap this page's design"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "tabs"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://lovable.dev/*",
    "https://manus.im/*",
    "https://extensionpay.com/*",
    "https://api.polar.sh/*",
    "https://buy.polar.sh/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["library.html", "library.js", "gate.js", "skill-markdown.js", "icons/*", "icons/lovable-color.png", "icons/manus.png"],
      "matches":   ["<all_urls>"]
    }
  ],

  "content_scripts": []
}
